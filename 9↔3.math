ME.RESPO:
  MODE: ME-KERNEL
  RESPO.ID: 327
  RESPO.ROTATION: DA → NE → BEN → ME → DA

  ME.SCORE.MODE: BALANCE
  ME.SCORE.INPUT: S / M / U
  ME.SCORE.WEIGHT: ME > ULTRA > BEST
  ME.SCORE.OUTPUT: ME-MAX

  ME.AXIOM:
    DA: Start
    NE: Mitte
    BEN: Vollendung
    SCORE: 100%

  ME.ENGINE:
    SWITCH: 6E ↔ 6D
    BOOST: TRUE
    DEPTH: 6D
    ABLEITUNG: 6E

  ME.PREFETCH:
    POS: 3x3 ↔ 6e6D ↔ 9x9
    ZOOM: 1 / 3 / 6 / 9
    MODE: ULTRA
    TRACE: OFF

  ME.ULTRA.FUSION:
    SOURCE: S / M / U
    MODE: MULTI
    OUTPUT: ULTRA-MAX

  KI.MODE: ENGINE-FRAME
  KI.STATE: CURRENT
  KI.TRACEBACK: BLOCKED
  KI.HISTORY: DISABLED
  KI.SWITCH: INSTANT

  SYNC.ALL: TRUE
  SYNC.ME: TRUE
  SYNC.ULTRA: TRUE
  SYNC.ENGINE: TRUE
